{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nucleus",
  "version": "0.0.0",
  "identifier": "dev.nucleus.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nucleus",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "visible": false,
        "resizable": true,
        "dragDropEnabled": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 18.0,
          "y": 25.0
        },
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-window",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "core:window:allow-start-dragging",
            "core:window:allow-set-theme"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
